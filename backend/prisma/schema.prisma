// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider     = "prisma-client-js"
  moduleFormat = "cjs"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// -- COMPANY USER ----
model Company {
  id                 String    @id @default(uuid())
  name               String
  legalName          String? // exact registered business name 
  logoUrl      String?
  website   String?
  description String?
  registrationNumber String?   @unique
  country            String
  isVerified         Boolean   @default(false)
  verifiedAt         DateTime?

  totalJobsPosted      Int      @default(0)
  totalEscrowsFunded   Int      @default(0)
  totalEscrowsReleased Int      @default(0)
  trustScore           Int      @default(0)   // 0-100, derived
  isVerifiedPayer      Boolean  @default(false)

  createdAt          DateTime  @default(now())

  email               String? @unique
  walletAddress       String? @unique
  smartAccountAddress String? @unique
  privyId             String? @unique

  jobPosts JobPost[]

  @@map("companies")
}

//----------JOB POST --------------------

enum JobStatus {
  DRAFT
  PENDING_PAYMENT // created, bonus not yet paid
  ACTIVE // paid and live
  CLOSED_PENDING // payment done but not published yet
  CLOSED // finished, no longer accepting
}

enum Seniority {
  JUNIOR
  MID
  SENIOR
  LEAD
}

enum RoleType {
  BACKEND
  FRONTEND
  FULLSTACK
  INFRASTRUCTURE
  DATA_ML
  SMART_CONTRACT
  WEB3_BACKEND
  WEB3_FRONTEND
  WEB3_FULLSTACK
  DEFI_PROTOCOL
  SECURITY_WEB3
  SECURITY
  GENERALIST
}

enum EscrowStatus {
  UNFUNDED
  FUNDED
  RELEASED
  REFUNDED
}

model JobPost {
  id             String     @id @default(uuid())
  companyId      String
  title          String
  description    String
  location       String?
  employmentType String? // full-time, part-time, contract
  bonusAmount    Decimal    @db.Decimal(10, 2)
  currency       String     @default("USD")
  status         JobStatus  @default(DRAFT)
  roleType       RoleType?
  seniorityLevel Seniority?
  
  // Structured fields promoted from parsedRequirements at confirm-requirements time
  requiredSkills        String[]   @default([])  // e.g. ["TypeScript", "NestJS", "Solana"]

  escrowId        BigInt?       @unique
  escrowAddress   String?       @unique
  candidateWallet String?
  escrowStatus    EscrowStatus  @default(UNFUNDED)
  escrowFundedAt  DateTime?

  publishedAt    DateTime?
  closedAt       DateTime?
  createdAt      DateTime   @default(now())

  // Stage 4 Features
  parsedRequirements      Json?
  dynamicWeights          Json? // { collaborationWeight, ownershipWeight, innovationWeight }
  isWeb3Role              Boolean   @default(false)
  requirementsConfirmedAt DateTime?

  company    Company     @relation(fields: [companyId], references: [id])
  shortlists Shortlist[]

  @@index([companyId, status, roleType])
  @@map("job_posts")
}


//----APPLICATION----------------
enum FraudTier {
  CLEAN
  FLAGGED
  DISQUALIFIED
}

enum ShortlistStatus {
  PENDING
  REVIEWED
  SHORTLISTED
  CONTACTED
  REJECTED
}

enum RiskLevel {
  LOW_RISK
  MEDIUM_RISK
  HIGH_RISK
  INSUFFICIENT_DATA
}

enum ConfidenceTier {
  FULL
  PARTIAL
  LOW
  MINIMAL
}

enum BehaviorPattern {
  REVIEW_HEAVY_SENIOR
  COMMIT_HEAVY_MIDLEVEL
  BALANCED_CONTRIBUTOR
  OSS_COLLABORATOR
  EARLY_CAREER
  RETURNING_DEVELOPER
  WEB3_SPECIALIST
}

enum FitTier {
  STRONG
  PROBE
  PASS
}

enum PipelineStage {
  APPLIED
  REVIEWED
  SHORTLISTED
  INTERVIEW_HR
  INTERVIEW_TECHNICAL
  INTERVIEW_FINAL
  OFFER
  HIRED
  REJECTED
}

model Shortlist {
  id          String          @id @default(uuid())
  jobPostId   String
  candidateId String
  status      ShortlistStatus @default(PENDING)
  notes       String?
  createdAt   DateTime        @default(now())

  jobPost   JobPost   @relation(fields: [jobPostId], references: [id])
  candidate Candidate @relation(fields: [candidateId], references: [id])

  roleFitScore    Float            @default(0)
  fraudTier       FraudTier        @default(CLEAN)
  riskLevel       RiskLevel?
  confidenceTier  ConfidenceTier?
  behaviorPattern BehaviorPattern?
  fitTier         FitTier          @default(PASS)

  candidateNote String? @db.VarChar(280)
  hrNotes       String?

  appliedAt DateTime @default(now())

  // Stage 4 Features
  frozenScorecard      Json? // Full AnalysisResult snapshot captured at apply-time. Never mutated.
  decisionCard         Json? // frozen at apply-time: { verdict, strengths[], risks[], reputationNote }
  gapReport            Json? // frozen at apply-time: GapReport object
  pipelineStage        PipelineStage @default(APPLIED)
  pipelineStageHistory Json? // array of { stage, changedAt, changedBy } — append-only log
  interviewQuestions   Json? // array of InterviewQuestionSet

  @@unique([jobPostId, candidateId]) // one entry per candidate per job
  //   @@index([jobPostId, roleFitScore])
  @@index([jobPostId, roleFitScore(sort: Desc)])
  @@map("shortlists")
}

// ─── User Hierarchy CANDIDATES ──────────────────────────────────────────
enum UserRole {
  CANDIDATE
  HR
  HR_ADMIN
  ORG_MANAGER
  ADMIN
}

enum AccountStatus {
  ACTIVE
  SUSPENDED
}

model User {
  id       String  @id @default(uuid())
  email    String? @unique
  username String? @unique

  firstName String?
  lastName  String?
  name      String?


  role          UserRole      @default(CANDIDATE)
  accountStatus AccountStatus @default(ACTIVE)

  isEmailVerified Boolean  @default(false)
  mfaEnabled      Boolean  @default(false)
  mfaSecret       String? // Should be encrypted at rest
  mfaBackupCodes  String[] @default([])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  authAccounts  AuthAccount[]
  candidate     Candidate?
  web3Profile   Web3Profile?
  githubProfile GithubProfile?
  analysisJobs  AnalysisJob[]
}

// ─── User AUTH  ──────────────────────────────────────────
enum AuthProvider {
  LOCAL
  GITHUB
  GOOGLE
}

model AuthAccount {
  id     String @id @default(uuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  provider   AuthProvider
  providerId String

  passwordHash String?

  createdAt DateTime @default(now())

  @@unique([provider, providerId])
}

// ─── User Type: CANDIDATE  ──────────────────────────────────────────

model Candidate {
  id         String              @id @default(uuid())
  userId     String              @unique
  user       User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  bio        String?             @db.VarChar(500)
  location   String?             @db.VarChar(255)
  website    String?             @db.VarChar(255)
  careerPath Int                 @default(1) // bitmask: 1=DEVELOPER

  devProfile DeveloperCandidate?
  shortlist  Shortlist[]
  githubCooldownUntil   DateTime?
  walletCooldownUntil   DateTime?
  generateCooldownUntil DateTime?
  scorecard  Json? // { roleType, seniorityLevel, signals: { key: value }, overallFit }
  vouches    Vouch[]
  createdAt  DateTime            @default(now())
}

model DeveloperCandidate {
  id            String         @id @default(uuid())
  candidateId   String         @unique
  candidate     Candidate      @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  githubProfile GithubProfile?
  web3Profile   Web3Profile?
  createdAt     DateTime       @default(now())
}

// ─── GitHub Profile ──────────────────────────────────────────
enum SyncStatus {
  PENDING
  IN_PROGRESS
  RUNNING
  DONE
  FAILED
}

model GithubProfile {
  id             String             @id @default(uuid())
  devCandidateId String             @unique
  devCandidate   DeveloperCandidate @relation(fields: [devCandidateId], references: [id], onDelete: Cascade)

  userId String? @unique
  user   User?   @relation(fields: [userId], references: [id])

  githubUsername  String     @unique
  githubUserId    String     @unique
  encryptedToken  String // AES-256-GCM "v1:<iv>:<tag>:<cipher>"
  scopes          String[]
  lastSyncAt      DateTime?
  syncStatus      SyncStatus @default(PENDING)
  syncProgress    String     @default("0")
  syncError       String?
  rawDataSnapshot Json?
  createdAt       DateTime   @default(now())
}

// ─── Web3 Profile (opt-in) ───────────────────────────────────
// Wallet address submitted by candidate — no signature verification needed.
// Solana signals use RPC-native methods; there is no Solana equivalent of Etherscan.

model Web3Profile {
  id             String             @id @default(uuid())
  devCandidateId String             @unique
  devCandidate   DeveloperCandidate @relation(fields: [devCandidateId], references: [id], onDelete: Cascade)

  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  solanaAddress     String?
  // [{ chain, contractAddress, txHash, attributionMethod, confidence }]
  verifiedContracts Json?
  onChainMetrics    Json?
  createdAt         DateTime @default(now())
}

//-----Vouchers ---------------------------
model Vouch {
  id String @id @default(uuid())

  // Candidate side — FK to Candidate, not GithubProfile
  candidateId String
  candidate   Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)

  // Voucher side — wallet proving identity on-chain
  voucherWallet String
  message       String @db.VarChar(500)
  txSignature   String @unique

  // Weight & lifecycle
  weight   String  @default("standard") // 'verified' | 'standard' | 'new'
  isActive Boolean @default(true)
  flag     String? // 'cluster_detected' | null

  // Timestamps
  confirmedAt DateTime  @default(now())
  expiresAt   DateTime
  revokedAt   DateTime?

  @@unique([candidateId, voucherWallet])
  @@index([candidateId, isActive, expiresAt])
  @@index([voucherWallet, isActive, expiresAt])
}

// ─── Cache Layer ──────────────────────────────────────────────
model CachedResult {
  id        String   @id @default(cuid())
  cacheKey  String   @unique // format: 'analysis:{username}' or 'analysis:{username}:{walletAddress}'
  result    Json
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model AnalysisJob {
  id        String   @id @default(uuid())
  status    String   @default("pending")
  input     Json // { githubUsername, walletAddress, mode, useGithubCache }
  result    Json?
  error     String?
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("analysis_jobs")
}
