{
  "moduleFileExtensions": ["js", "json", "ts"],
  "rootDir": ".",
  "testEnvironment": "node",
  "setupFiles": ["<rootDir>/setup.ts", "<rootDir>/setup-e2e.ts"],
  "setupFilesAfterEnv": ["<rootDir>/jest.setup.ts"],
  "testRegex": ".e2e-spec.ts$",
  "transform": {
    "^.+\\.(t|j)s$": "ts-jest"
  },
  "moduleNameMapper": {
    "^src/(.*)$": "<rootDir>/../src/$1"
  },
  "transformIgnorePatterns": [
    "node_modules/(?!(jose|@privy-io|@octokit|octokit|universal-user-agent|before-after-hook|is-plain-object|node-fetch|@scure|@noble|otplib)/)"
  ]
}
